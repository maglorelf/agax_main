<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep direct access to existing files and folders
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback all client-side routes to index.html
  RewriteRule . /index.html [L]
</IfModule>
